# Containers and Umbrel application
HERMES_CONTAINER=hermes-agent_web_1
UMBREL_CONTAINER=Umbrel
HERMES_APP_ID=hermes-agent

# Persistent paths inside the Hermes container
HERMES_DATA_DIR=/opt/data
HERMES_CLI=/opt/hermes/.venv/bin/hermes
HERMES_PYTHON=/opt/hermes/.venv/bin/python

# Hermes model routing: primary -> NVIDIA -> local Ollama
HERMES_PRIMARY_PROVIDER=openai-codex
HERMES_PRIMARY_MODEL=gpt-5.6-luna
HERMES_NVIDIA_PROVIDER=nvidia
HERMES_NVIDIA_FALLBACK_MODEL=openai/gpt-oss-120b
HERMES_OLLAMA_PROVIDER=ollama
HERMES_OLLAMA_BASE_URL=http://ollama_ollama_1:11434/v1
HERMES_OLLAMA_MODEL=qwen3:4b-instruct
HERMES_OLLAMA_TIMEOUT=900

# CUA Driver running on the Windows host through SSH
CUA_SSH_HOST=windows-host-or-tailscale-ip
CUA_SSH_PORT=22
CUA_SSH_USER=windows-user
CUA_SSH_KEY=/opt/data/home/.ssh/your-private-key
CUA_WINDOWS_EXECUTABLE=C:\Users\windows-user\AppData\Local\Programs\Cua\cua-driver\bin\cua-driver.exe

# TorrentClaw MCP package version (pin for reproducible installs)
TORRENTCLAW_VERSION=0.2.1

# qBittorrent Web API available from the Hermes Docker network
QBITTORRENT_BASE_URL=http://qbittorrent_server_1:8080
QBITTORRENT_USERNAME=admin
QBITTORRENT_PASSWORD=
QBITTORRENT_PASSWORD_FILE=/opt/data/secrets/qbittorrent_password
QBITTORRENT_TIMEOUT=15
